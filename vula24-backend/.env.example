# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vula24?schema=public"
# Railway (API + DB on Railway): use the Postgres URL from Variables → Reference.
# Append TLS for Prisma: ?sslmode=require (often required or you get 500s on DB calls).
# Example: postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway?sslmode=require
# From your laptop only: public TCP proxy host + ?sslmode=require (internal host only works inside Railway).

# JWT for customers, locksmiths, team members
JWT_SECRET=change-me-to-a-long-random-string

# Admin tokens are signed with this secret (use a strong random value)
ADMIN_SECRET=change-me-admin-signing-secret

# PayFast (sandbox: https://sandbox.payfast.co.za)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# Public base URL of this API (PayFast return_url / notify_url; optional override for uploaded file URLs)
# If unset, file URLs use the incoming request Host (good for LAN testing with a phone).
APP_URL=http://localhost:3000

# Admin notifications (withdrawals, etc.) — recipientId stored on Notification
ADMIN_NOTIFICATION_RECIPIENT_ID=admin

# Cloudinary (locksmith registration photos). If unset, files are stored under uploads/locksmith on disk.
# Dashboard → copy "API Environment variable" as CLOUDINARY_URL, or set the three vars below.
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional folder prefix (default vula24/locksmith)
# CLOUDINARY_LOCKSMITH_FOLDER=vula24/locksmith
