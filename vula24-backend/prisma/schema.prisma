generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  INDIVIDUAL
  BUSINESS
}

enum ServiceType {
  CAR_LOCKOUT
  HOUSE_LOCKOUT
  OFFICE_LOCKOUT
  KEY_DUPLICATION
  CAR_KEY_PROGRAMMING
  CAR_KEY_CUTTING
  BROKEN_KEY_EXTRACTION
  LOST_KEY_REPLACEMENT
  IGNITION_REPAIR
  LOCK_REPLACEMENT
  LOCK_REPAIR
  LOCK_UPGRADE
  DEADLOCK_INSTALLATION
  SAFE_OPENING
  GATE_MOTOR_REPAIR
  ACCESS_CONTROL
  PADLOCK_REMOVAL
  GARAGE_DOOR
  SECURITY_GATE
  ELECTRIC_FENCE_GATE
}

enum JobMode {
  EMERGENCY
  SCHEDULED
}

enum JobStatus {
  PENDING
  ACCEPTED
  DISPATCHED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum WalletTxType {
  CREDIT
  DEBIT
}

enum RecipientType {
  CUSTOMER
  LOCKSMITH
  TEAM_MEMBER
}

enum PaymentMethod {
  APP
  CASH
}

model Customer {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  email        String   @unique
  password     String
  pushToken    String?
  profilePhoto String?
  strikeCount  Int      @default(0)
  isBanned     Boolean  @default(false)
  bannedAt     DateTime?
  bannedReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs    Job[]
  reviews Review[]
}

model Locksmith {
  id                String      @id @default(uuid())
  name              String
  phone             String      @unique
  email             String      @unique
  password          String
  pushToken         String?
  accountType       AccountType
  businessName      String?
  psiraNumber       String?
  psiraVerified     Boolean     @default(false)
  idPhotoUrl        String?
  selfiePhotoUrl    String?
  toolsPhotoUrl     String?
  proofOfAddressUrl String?
  bankName          String?
  bankAccountNumber String?
  bankAccountHolder String?
  isVerified        Boolean     @default(false)
  isOnline          Boolean     @default(false)
  isSuspended       Boolean     @default(false)
  currentLat        Float?
  currentLng        Float?
  rating            Float       @default(5.0)
  totalJobs         Int         @default(0)
  walletMinimum     Float       @default(200)
  profilePhoto      String?
  vehicleType       String?
  vehicleColor      String?
  vehiclePlateNumber String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  teamMembers    TeamMember[]
  servicePricing ServicePricing[]
  jobs           Job[]            @relation("JobLocksmith")
  quotes         Quote[]
  reviews        Review[]
  wallet         Wallet?
  pendingPayouts PendingPayout[]
}

model TeamMember {
  id                 String    @id @default(uuid())
  businessId         String
  business           Locksmith @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name               String
  phone              String
  idPhotoUrl         String?
  profilePhoto       String?
  vehicleType        String?
  vehicleColor       String?
  vehiclePlateNumber String?
  appEmail           String    @unique
  appPassword        String
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())

  jobs Job[]
}

model ServicePricing {
  id          String      @id @default(uuid())
  locksithId  String
  locksmith   Locksmith   @relation(fields: [locksithId], references: [id], onDelete: Cascade)
  serviceType ServiceType
  basePrice   Float
  isOffered   Boolean     @default(true)

  @@unique([locksithId, serviceType])
}

model Job {
  id                String      @id @default(uuid())
  customerId        String
  customer          Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  locksithId        String?
  locksmith         Locksmith?  @relation("JobLocksmith", fields: [locksithId], references: [id], onDelete: SetNull)
  teamMemberId      String?
  teamMember        TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  serviceType       ServiceType
  mode              JobMode
  status            JobStatus
  customerLat       Float
  customerLng       Float
  customerAddress   String
  customerNote      String?
  jobPhotoUrl       String?
  scheduledDate     DateTime?
  locksithBasePrice Float
  travelFee         Float
  platformFee       Float
  totalPrice        Float
  locksithEarning   Float
  depositPaid       Boolean     @default(false)
  finalPaid         Boolean     @default(false)
  paymentMethod     PaymentMethod @default(APP)
  cashCollected     Float?
  isDisputed        Boolean     @default(false)
  disputeProofUrl   String?
  disputeResolvedAt DateTime?
  disputeNotes      String?
  disputeReason     String?
  createdAt         DateTime    @default(now())
  acceptedAt        DateTime?
  completedAt       DateTime?
  updatedAt         DateTime    @updatedAt

  quotes         Quote[]
  review         Review?
  transactions   Transaction[] @relation("JobWalletTx")
  pendingPayout  PendingPayout?
}

model Quote {
  id         String      @id @default(uuid())
  jobId      String
  job        Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  locksithId String
  locksmith  Locksmith   @relation(fields: [locksithId], references: [id], onDelete: Cascade)
  price      Float
  message    String?
  status     QuoteStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  @@unique([jobId, locksithId])
}

model Review {
  id         String    @id @default(uuid())
  jobId      String    @unique
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  locksithId String
  locksmith  Locksmith @relation(fields: [locksithId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime  @default(now())
}

model Wallet {
  id              String    @id @default(uuid())
  locksithId      String    @unique
  locksmith       Locksmith @relation(fields: [locksithId], references: [id], onDelete: Cascade)
  balance         Float     @default(0)
  minimumBalance  Float     @default(200)
  updatedAt       DateTime  @updatedAt

  transactions Transaction[]
}

model Transaction {
  id          String       @id @default(uuid())
  walletId    String
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Float
  type        WalletTxType
  description String
  jobId       String?
  job         Job?         @relation("JobWalletTx", fields: [jobId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())

  @@map("transactions")
}

model Notification {
  id            String        @id @default(uuid())
  recipientId   String
  recipientType RecipientType
  title         String
  message       String
  isRead        Boolean       @default(false)
  createdAt     DateTime      @default(now())
}

model PendingPayout {
  id           String    @id @default(uuid())
  jobId        String    @unique
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  locksithId   String
  locksmith    Locksmith @relation(fields: [locksithId], references: [id], onDelete: Cascade)
  amount       Float
  releaseAfter DateTime
  released     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@map("pending_payouts")
}
