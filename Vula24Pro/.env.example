# API base URL (no trailing slash). Required for registration/login against Railway from a real device.
#
# Production (same API as Vula24 customer app unless you deploy separately)
EXPO_PUBLIC_API_URL=https://vula24-production.up.railway.app
#
# Local backend from a phone on the same Wi‑Fi (use your PC's LAN IP)
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
# If unset, the app guesses Metro LAN host :3000 — unreliable off Wi‑Fi or when API is only on Railway.

# Optional. Android Maps key for com.vula24.pro (app.config.js).
# GOOGLE_MAPS_ANDROID_KEY=
