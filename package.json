{
  "name": "vula24",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "npm install --prefix ./vula24-backend && npm run prisma:generate --prefix ./vula24-backend",
    "start": "node vula24-backend/scripts/start.js",
    "start:client": "npx expo start ./Vula24",
    "start:client:dev": "npx expo start ./Vula24 --dev-client",
    "eas:build:dev": "cd Vula24 && eas build --profile development --platform android",
    "eas:build:dev:pro": "cd Vula24Pro && eas build --profile development --platform android",
    "start:customer": "npm run start:client",
    "start:pro": "npx expo start ./Vula24Pro",
    "start:pro:dev": "npx expo start ./Vula24Pro --dev-client --port 8082"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "expo-dev-client": "~55.0.27"
  }
}
