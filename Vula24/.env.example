# Optional override. If unset, the app uses Expo’s Metro host (same LAN as your PC) so
# physical phones usually work without editing this. Android emulator uses 10.0.2.2.
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000

# Optional. Android Google Maps key (read at build time by app.config.js). Use the same
# key as Vula24 Pro if your Google key allows both package names. Otherwise set in app.json.
# GOOGLE_MAPS_ANDROID_KEY=
