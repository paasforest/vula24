# API base URL (no trailing slash). First matching line wins if you use a single active URL.
#
# Local backend from a phone on the same Wi‑Fi (use your PC's LAN IP; run: ip -brief addr)
# EXPO_PUBLIC_API_URL=http://192.168.0.108:3000
#
# Production — must have DB migrations applied on Railway or auth returns 500.
# EXPO_PUBLIC_API_URL=https://vula24-production.up.railway.app
#
# If unset, Expo uses the same host as Metro (LAN) :3000; Android emulator uses 10.0.2.2:3000.

# Optional. Android Google Maps key (read at build time by app.config.js). Use the same
# key as Vula24 Pro if your Google key allows both package names. Otherwise set in app.json.
# GOOGLE_MAPS_ANDROID_KEY=
